# Villa Sirene — Email Configuration
#
# Option A (recommended): Amazon SES via IAM role — no credentials needed here.
#   Just attach an IAM role with AmazonSESFullAccess to the EC2 instance.
#   Optionally override the defaults below:
#
# SES_REGION=eu-central-1
# SES_SENDER=verified-email@example.com
#
# Option B: SMTP relay (e.g. Gmail with App Password)
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-16-char-app-password
